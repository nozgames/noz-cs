<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0-ios</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <RootNamespace>noz</RootNamespace>
    <SupportedOSPlatformVersion>15.0</SupportedOSPlatformVersion>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\desktop\NoZ.Desktop.csproj" />
    <ProjectReference Include="..\webgpu\NoZ.WebGPU.csproj" />
  </ItemGroup>

  <!-- wgpu-native static library — device build -->
  <ItemGroup Condition="!$(RuntimeIdentifier.Contains('simulator'))">
    <NativeReference Include="libs\device\libwgpu_native.a">
      <Kind>Static</Kind>
      <ForceLoad>true</ForceLoad>
    </NativeReference>
  </ItemGroup>

  <!-- wgpu-native static library — simulator build -->
  <ItemGroup Condition="$(RuntimeIdentifier.Contains('simulator'))">
    <NativeReference Include="libs\simulator\libwgpu_native.a">
      <Kind>Static</Kind>
      <ForceLoad>true</ForceLoad>
    </NativeReference>
  </ItemGroup>

</Project>
